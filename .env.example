# Server configuration
PORT=3000

# MongoDB connection string
# Local:  mongodb://localhost:27017/miniwall
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/miniwall
MONGO_URI=mongodb://localhost:27017/miniwall

# JWT configuration
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# Token expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d

# Environment: development | production | test
NODE_ENV=development
